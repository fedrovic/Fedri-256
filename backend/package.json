{
  "name": "skillswap-backend",
  "version": "1.0.0",
  "description": "SkillSwap peer-to-peer skill exchange platform — REST API",
  "main": "src/server.js",
  "engines": { "node": ">=20.0.0" },
  "scripts": {
    "dev":          "nodemon src/server.js",
    "start":        "node src/server.js",
    "test":         "NODE_ENV=test jest",
    "test:unit":    "NODE_ENV=test jest tests/unit --coverage",
    "test:int":     "NODE_ENV=test jest tests/integration --runInBand",
    "test:watch":   "NODE_ENV=test jest --watch",
    "lint":         "eslint src/**/*.js --fix",
    "db:migrate":   "prisma migrate dev",
    "db:deploy":    "prisma migrate deploy",
    "db:generate":  "prisma generate",
    "db:seed":      "node prisma/seed.js",
    "db:studio":    "prisma studio",
    "db:reset":     "prisma migrate reset --force && node prisma/seed.js",
    "docker:dev":   "docker compose up --build",
    "docker:down":  "docker compose down -v",
    "docker:tools": "docker compose --profile tools up -d"
  },
  "dependencies": {
    "@prisma/client":            "^5.10.0",
    "bcryptjs":                  "^2.4.3",
    "compression":               "^1.7.4",
    "cookie-parser":             "^1.4.6",
    "cors":                      "^2.8.5",
    "dotenv":                    "^16.4.1",
    "express":                   "^4.18.2",
    "express-async-errors":      "^3.1.1",
    "express-rate-limit":        "^7.2.0",
    "helmet":                    "^7.1.0",
    "ioredis":                   "^5.3.2",
    "jsonwebtoken":              "^9.0.2",
    "morgan":                    "^1.10.0",
    "multer":                    "^1.4.5-lts.1",
    "nodemailer":                "^6.9.9",
    "passport":                  "^0.7.0",
    "passport-github2":          "^0.1.12",
    "passport-google-oauth20":   "^2.0.0",
    "passport-jwt":              "^4.0.1",
    "socket.io":                 "^4.7.4",
    "speakeasy":                 "^2.0.0",
    "stripe":                    "^14.18.0",
    "uuid":                      "^9.0.0",
    "winston":                   "^3.11.0",
    "zod":                       "^3.22.4"
  },
  "devDependencies": {
    "eslint":    "^8.57.0",
    "jest":      "^29.7.0",
    "nodemon":   "^3.0.3",
    "prisma":    "^5.10.0",
    "supertest": "^6.3.4"
  }
}
