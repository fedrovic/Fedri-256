{
  "builds": [
    { "src": "frontend/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/", "dest": "/skillswap-landing.html" },
    { "src": "/auth", "dest": "/skillswap-auth.html" },
    { "src": "/onboarding", "dest": "/skillswap-onboarding.html" },
    { "src": "/dashboard", "dest": "/skillswap-dashboard.html" },
    { "src": "/discover", "dest": "/skillswap-discover.html" },
    { "src": "/profile", "dest": "/skillswap-profile.html" },
    { "src": "/swaps", "dest": "/skillswap-swaps.html" },
    { "src": "/messages", "dest": "/skillswap-messages.html" },
    { "src": "^/(.*)", "dest": "/skillswap-landing.html" }
  ]
}
