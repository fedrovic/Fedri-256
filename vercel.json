{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "public" }
    }
  ],
  "rewrites": [
    { "source": "/", "destination": "/skillswap-landing.html" },
    { "source": "/auth", "destination": "/skillswap-auth.html" },
    { "source": "/onboarding", "destination": "/skillswap-onboarding.html" },
    { "source": "/dashboard", "destination": "/skillswap-dashboard.html" },
    { "source": "/discover", "destination": "/skillswap-discover.html" },
    { "source": "/profile", "destination": "/skillswap-profile.html" },
    { "source": "/swaps", "destination": "/skillswap-swaps.html" },
    { "source": "/messages", "destination": "/skillswap-messages.html" },
    { "source": "/:path*", "destination": "/skillswap-landing.html" }
  ]
}
